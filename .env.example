# ── Free API keys ─────────────────────────────────────────────────────────────
# FRED (get free key at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_key_here

# Reddit (create app at https://www.reddit.com/prefs/apps — choose "script")
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=lumina-research/0.1

# SEC EDGAR (no key required, just set a contact email per EDGAR policy)
EDGAR_USER_AGENT=Lumina Research contact@example.com

# Kalshi prediction markets (create an API key at https://kalshi.com/account/api)
# Auth uses RSA-signed custom headers, NOT JWT. Provide the key ID and PEM private key path.
KALSHI_API_KEY=your_kalshi_key_id
KALSHI_PRIVATE_KEY_PATH=/app/kalshi_private_key.pem

# ── Internal config ────────────────────────────────────────────────────────────
DATA_DIR=/app/data
SIGNALS_DB_PATH=/app/data/signals/signals.db
FEATURES_DIR=/app/data/features
RAW_DIR=/app/data/raw

MLFLOW_TRACKING_URI=http://mlflow:5001
MLFLOW_EXPERIMENT_NAME=lumina-regime-classifier

# ── Ingestion config ───────────────────────────────────────────────────────────
REDDIT_SUBREDDITS=investing,MacroEconomics,wallstreetbets,Economics,stocks
REDDIT_POST_LIMIT=500
GDELT_LOOKBACK_DAYS=7
EDGAR_FORM_TYPES=8-K,10-K
FRED_SERIES=UNRATE,CPIAUCSL,DGS10,DGS2,T10YIE,VIXCLS,DTWEXBGS,BAMLH0A0HYM2,MORTGAGE30US

# ── Model config ───────────────────────────────────────────────────────────────
FINBERT_MODEL=ProsusAI/finbert
BERTOPIC_MIN_TOPIC_SIZE=10
REGIME_MODEL_VERSION=latest
