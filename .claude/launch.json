{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "frontend"
    },
    {
      "name": "api",
      "runtimeExecutable": "./api/.venv/bin/uvicorn",
      "runtimeArgs": ["main:app", "--reload", "--port", "8000", "--app-dir", "api"],
      "port": 8000
    },
    {
      "name": "mlflow",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "mlflow"],
      "port": 5001
    }
  ]
}
